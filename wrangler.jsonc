{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "legaltech-ai-hub",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "legaltech-ai-hub"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "enabled": true
  },
  // Environment variables (non-secret)
  "vars": {
    "SENDGRID_FROM_EMAIL": "contact@legaltech-ai-hub.com",
    "CONTACT_TO_EMAIL": "moonsmoke.contact@gmail.com"
  }
  // Secret variables (SENDGRID_API_KEY) should be set via:
  //   Local dev:  .dev.vars file
  //   Production: `npx wrangler secret put SENDGRID_API_KEY`
  //   Or via Cloudflare Dashboard → Workers → Settings → Variables and Secrets
}
